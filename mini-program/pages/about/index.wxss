.about { background: linear-gradient(180deg, #fff7e0 0%, #fff 100%); min-height: 100vh; padding: 40rpx 32rpx; }
.hero { text-align: center; padding: 24rpx 0 40rpx; }
.mascot { font-size: 160rpx; line-height: 1; }
.title {
  margin-top: 16rpx;
  font-size: 44rpx; font-weight: 900;
  background: linear-gradient(180deg, #ff8c42, #d8395d);
  -webkit-background-clip: text; background-clip: text;
  color: transparent;
}
.sub { font-size: 24rpx; color: #666; margin-top: 8rpx; }
.block { background: #fff; border: 4rpx solid #ffe082; border-radius: 24rpx; padding: 24rpx; margin-bottom: 20rpx; }
.bt { font-size: 28rpx; font-weight: 900; color: #b56500; margin-bottom: 10rpx; }
.bb { font-size: 26rpx; color: #555; line-height: 1.6; }
