.home {
  width: 100vw;
  height: 100vh;
  background:
    radial-gradient(ellipse 130% 70% at 50% 110%, #5fa315 0%, #5fa315 35%, transparent 36%),
    linear-gradient(180deg, #ffd9e8 0%, #ffb8d4 40%, #c8f04a 70%, #9ed838 100%);
  position: relative;
  overflow: hidden;
}

.top {
  position: absolute;
  top: 90rpx; left: 24rpx; right: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.coin-pill {
  background: rgba(0,0,0,0.55);
  color: #fff;
  border: 5rpx solid #fff;
  border-radius: 36rpx;
  padding: 8rpx 20rpx 8rpx 12rpx;
  display: flex; align-items: center; gap: 12rpx;
  font-size: 26rpx; font-weight: 700;
}
.coin-emoji {
  width: 44rpx; height: 44rpx;
  background: radial-gradient(circle at 30% 30%, #ffed7a, #f5b40a);
  border-radius: 50%;
  border: 3rpx solid #c98300;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
}
.streak-pill {
  background: linear-gradient(180deg, #ff6f8d, #d8395d);
  color: #fff;
  border: 5rpx solid #fff;
  border-radius: 36rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx; font-weight: 700;
}

.stage {
  position: absolute;
  top: 200rpx; left: 0; right: 0; bottom: 540rpx;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.title-en {
  font-weight: 700;
  font-size: 72rpx;
  background: linear-gradient(90deg, #ff5e9b 0%, #ff9a3a 30%, #ffd24a 50%, #6fc6ff 75%, #b076ff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: 2rpx;
}
.title-zh {
  font-size: 36rpx;
  color: #d8395d;
  letter-spacing: 12rpx;
  margin-top: 4rpx;
}
.mascot {
  font-size: 240rpx;
  line-height: 1;
  margin-top: 20rpx;
  filter: drop-shadow(0 16rpx 0 rgba(0,0,0,0.12));
}
.speech-bubble {
  margin-top: 24rpx;
  background: #fff;
  border: 5rpx solid #ffb1c1;
  border-radius: 36rpx;
  padding: 14rpx 28rpx;
  font-size: 28rpx;
  color: #d8395d;
  font-weight: 700;
}

.bottom {
  position: absolute;
  left: 24rpx; right: 24rpx;
  bottom: 60rpx;
}
.stat-strip {
  display: flex;
  background: rgba(255,255,255,0.95);
  border: 5rpx solid #fff;
  border-radius: 28rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
}
.stat { flex: 1; text-align: center; }
.stat + .stat { border-left: 2rpx dashed rgba(216,57,93,0.3); }
.stat-n {
  font-size: 44rpx; font-weight: 900;
  background: linear-gradient(180deg, #ff8c42, #d8395d);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.stat-l { font-size: 22rpx; color: #888; margin-top: 4rpx; }

.play-btn {
  width: 100%;
  height: 128rpx;
  background: linear-gradient(180deg, #6fc6ff, #2b88d6);
  color: #fff;
  border: 6rpx solid #fff;
  border-radius: 44rpx;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 14rpx;
  box-shadow: 0 12rpx 0 #1a5e9c;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 20rpx;
}
.play-btn::after { border: none; }

.grid {
  display: flex; gap: 20rpx;
}
.grid-btn {
  flex: 1;
  height: 96rpx;
  background: #ffd24a;
  color: #5c3700;
  border: 5rpx solid #fff;
  border-radius: 28rpx;
  font-size: 26rpx; font-weight: 800;
  box-shadow: 0 8rpx 0 #cb8e0e;
  display: flex; align-items: center; justify-content: center;
}
.grid-btn::after { border: none; }
