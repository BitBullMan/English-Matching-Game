# 复制为 .env.local，按需填写
# ——————————————————————————
# 语音
# ——————————————————————————

# provider: browser (默认 / 免费 / 离线) | openai (类人音质)
VITE_TTS_PROVIDER=browser

# ===== 选 openai 时才需要 =====

# 推荐方式：走自家后端代理（保护 API Key）
VITE_OPENAI_TTS_PROXY=

# 仅本地调试可直填 key
VITE_OPENAI_API_KEY=

# TTS 模型：tts-1 (便宜快) / tts-1-hd (音质好) / gpt-4o-mini-tts (最新最自然，支持 instructions) ★
VITE_OPENAI_TTS_MODEL=gpt-4o-mini-tts

# voice：alloy / ash / ballad / coral / echo / fable / nova / onyx / sage / shimmer
# ⚠️ 注意：你截图里的 Arbor 是 ChatGPT 应用专属，TTS API 没有。
# 风格最接近 Arbor（easygoing & versatile）的：ash / sage / ballad
VITE_OPENAI_VOICE_UK=ash
VITE_OPENAI_VOICE_US=sage
